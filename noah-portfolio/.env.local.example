OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_TOKEN=
# Server-only HMAC key used for private Story cache identity. Use a long random value in production.
STORY_CACHE_HMAC_KEY=
# Non-secret rotation label. Change it whenever STORY_CACHE_HMAC_KEY changes.
STORY_CACHE_HMAC_KEY_ID=
# Langfuse observability (optional). When both keys are set, Story generations are traced.
# Keys: Langfuse project > Settings > API Keys. Leave unset to disable tracing locally.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Base URL selects the data region: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US), or a self-hosted URL.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
